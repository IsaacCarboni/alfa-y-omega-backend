<div style="font-family: sans-serif; padding: 20px;">
    <h2 style="color: #c9302c; text-align: center;">📸 Auditoría de Heladeras y Batea</h2>
    <hr>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; margin-top: 20px;">
        {{#each images}}
            <div style="border: 1px solid #ddd; border-radius: 10px; overflow: hidden; background: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                <img src="/img/{{this}}" alt="Foto Auditoría" style="width: 100%; height: 200px; object-fit: cover;">
                <div style="padding: 10px; text-align: center;">
                    <p style="font-size: 12px; color: #666; margin: 0;"><b>Archivo:</b> {{this}}</p>
                </div>
            </div>
        {{else}}
            <p style="text-align: center; grid-column: 1 / -1;">No hay fotos de auditoría registradas todavía.</p>
        {{/each}}
    </div>

    <div style="text-align: center; margin-top: 30px;">
        <a href="/test-upload" style="background: #333; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px;">Ir a Subir Foto</a>
    </div>
</div>